{
    "name": "monkeyscloud/monkeyslegion-validation",
    "description": "Attribute-driven validation & DTO binding for the MonkeysLegion PHP 8.4 framework — self-validating constraints, property hooks, PSR-15 middleware.",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "keywords": ["validation", "attributes", "dto", "monkeyslegion", "php84", "property-hooks"],
    "authors": [
        {
            "name": "MonkeysCloud",
            "email": "jorge@monkeys.cloud"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "ext-mbstring": "*",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/http-factory": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1",
        "guzzlehttp/psr7": "^2.7",
        "http-interop/http-factory-guzzle": "^1.2"
    },
    "suggest": {
        "monkeyscloud/monkeyslegion-core": "For framework integration and service providers",
        "monkeyscloud/monkeyslegion-di": "For auto-wired DI container support"
    },
    "autoload": {
        "psr-4": {
            "MonkeysLegion\\Validation\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "MonkeysLegion\\Validation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0.x-dev"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --memory-limit=512M",
        "quality": [
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
